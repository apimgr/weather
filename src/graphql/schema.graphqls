type Notification {
  id: ID!
  userId: Int!
  type: String!
  title: String!
  message: String!
  read: Boolean!
  createdAt: Time!
  readAt: Time
}

type UnreadCount {
  count: Int!
}

type UserToken {
  id: ID!
  name: String
  tokenPrefix: String!
  scopes: String
  createdAt: Time!
  expiresAt: Time
  lastUsedAt: Time
  token: String
}

type UserSettings {
  account: AccountSettings!
  privacy: PrivacySettings!
  notifications: NotificationSettings!
  appearance: AppearanceSettings!
}

type AccountSettings {
  displayName: String!
  bio: String!
  location: String!
  website: String!
  timezone: String!
  language: String!
  dateFormat: String!
  timeFormat: String!
}

type PrivacySettings {
  visibility: String!
  showEmail: Boolean!
  showActivity: Boolean!
  showOrgs: Boolean!
  searchable: Boolean!
  orgVisibility: Boolean!
}

type NotificationSettings {
  emailSecurity: Boolean!
  emailMentions: Boolean!
  emailUpdates: Boolean!
  emailDigest: String!
  pushEnabled: Boolean!
  pushMentions: Boolean!
}

type AppearanceSettings {
  theme: String!
  fontSize: String!
  reduceMotion: Boolean!
}

input AccountSettingsInput {
  displayName: String!
  bio: String!
  location: String!
  website: String!
  timezone: String!
  language: String!
  dateFormat: String!
  timeFormat: String!
}

input PrivacySettingsInput {
  visibility: String!
  showEmail: Boolean!
  showActivity: Boolean!
  showOrgs: Boolean!
  searchable: Boolean!
  orgVisibility: Boolean!
}

input NotificationSettingsInput {
  emailSecurity: Boolean!
  emailMentions: Boolean!
  emailUpdates: Boolean!
  emailDigest: String!
  pushEnabled: Boolean!
  pushMentions: Boolean!
}

input AppearanceSettingsInput {
  theme: String!
  fontSize: String!
  reduceMotion: Boolean!
}

# ============================================================================
# ADMIN TYPES
# ============================================================================

type Setting {
  key: String!
  value: String
  type: String
  description: String
  updatedAt: Time
  updatedBy: String
}

type APIToken {
  id: ID!
  token: String
  name: String
  createdAt: Time!
  expiresAt: Time
  lastUsedAt: Time
  lastUsedIP: String
}

type AuditLog {
  id: ID!
  userId: Int
  action: String!
  resource: String
  details: String
  ip: String
  userAgent: String
  createdAt: Time!
}

type SystemStats {
  uptime: String!
  requests: RequestStats!
  users: UserStats!
  locations: LocationStats!
  notifications: NotificationStats!
  database: DatabaseStats!
}

type RequestStats {
  total: Int!
  perSecond: Float
  errors: Int
}

type UserStats {
  total: Int!
  active: Int
  admins: Int
}

type LocationStats {
  total: Int!
  perUser: Float
}

type NotificationStats {
  total: Int!
  unread: Int
}

type DatabaseStats {
  size: Float!
  tables: Int
  connections: Int
}

# ============================================================================
# SCHEDULER TYPES
# ============================================================================

type ScheduledTask {
  name: String!
  schedule: String!
  enabled: Boolean!
  lastRun: Time
  nextRun: Time
  runCount: Int!
  errorCount: Int!
  avgDuration: Float
}

type TaskHistory {
  taskName: String!
  startedAt: Time!
  completedAt: Time
  duration: Float
  ok: Boolean!
  error: String
}

# ============================================================================
# NOTIFICATION CHANNELS TYPES
# ============================================================================

type NotificationChannel {
  type: String!
  enabled: Boolean!
  config: Any
  stats: ChannelStats
}

type ChannelStats {
  sent: Int!
  failed: Int!
  lastSent: Time
}

type QueueStats {
  pending: Int!
  processing: Int!
  completed: Int!
  failed: Int!
}

type SMTPProvider {
  name: String!
  host: String!
  port: Int!
  secure: Boolean!
}

# ============================================================================
# CONTACT FORM TYPES
# ============================================================================

type ContactSubmission {
  ok: Boolean!
  message: String!
}

# ============================================================================
# GENERIC TYPES
# ============================================================================

type GenericResponse {
  ok: Boolean!
  message: String!
}

type UserInvite {
  id: ID!
  token: String!
  username: String!
  email: String!
  role: String!
  createdAt: Time!
  expiresAt: Time!
  maxUses: Int!
  useCount: Int!
  usedAt: Time
  status: String!
  inviteUrl: String!
}

type ServerAdmin {
  id: ID!
  username: String!
  email: String!
  isSuperAdmin: Boolean!
  isActive: Boolean!
  createdAt: Time!
  updatedAt: Time!
  lastLoginAt: Time
}

type ServerAdminOverview {
  count: Int!
  currentAdmin: ServerAdmin!
  onlineAdmins: [String!]!
  privacyNotice: String!
}

type ServerAdminInvite {
  token: String!
  email: String!
  expiresAt: Time!
  expiresIn: String!
  inviteUrl: String!
}

type BulkResponse {
  ok: Boolean!
  message: String!
  updated: Int
  failed: Int
}

# ============================================================================
# QUERY TYPE
# ============================================================================

type Query {
  # Health & Status
  health: HealthStatus!

  # Weather Endpoints
  weather(location: String, lat: Float, lon: Float): Weather!
  forecast(location: String, lat: Float, lon: Float, days: Int): Weather!
  searchLocations(query: String!): [LocationSearchResult!]!
  ipGeolocation(ip: String): IPGeolocation!
  currentLocation: IPGeolocation!
  historicalWeather(location: String!, date: String!): HistoricalWeather!

  # Location Lookups
  lookupZipCode(code: String!): ZipCodeLookup!
  lookupCoordinates(lat: Float!, lon: Float!): CoordinatesLookup!

  # Natural Disasters
  earthquakes(minMagnitude: Float, limit: Int): [Earthquake!]!
  hurricanes(active: Boolean): [Hurricane!]!
  severeWeather(location: String): [SevereWeather!]!
  moonPhase(date: String): MoonPhase!
  publicUserProfile(username: String!): PublicUserProfile
  validateUserInvite(token: String!): UserInviteValidation!
  validateServerInvite(token: String!): ServerInviteValidation!

  # User Endpoints (require authentication)
  currentUser: User!
  currentUserAvatar: PublicAvatar!
  currentUserTwoFactorStatus: TOTPStatus!
  currentUserTwoFactorSetup: TOTPSetup!
  userSettings: UserSettings!
  userTokens: [UserToken!]!

  # Saved Locations (require authentication)
  savedLocations: [SavedLocation!]!
  savedLocation(id: ID!): SavedLocation

  # Notifications (require authentication)
  notifications: [Notification!]!
  unreadNotifications: UnreadCount!

  # Admin Endpoints (require admin)
  adminUsers: [User!]!
  adminServerAdmins: ServerAdminOverview!
  adminServerAdmin(id: ID!): ServerAdmin
  adminUserInvites: [UserInvite!]!
  adminUserInvite(id: ID!): UserInvite
  adminSettings: [Setting!]!
  adminSetting(key: String!): Setting
  adminTokens: [APIToken!]!
  adminAuditLogs(limit: Int, offset: Int): [AuditLog!]!
  adminStats: SystemStats!
  adminTasks: [ScheduledTask!]!
  adminTaskHistory(name: String!, limit: Int): [TaskHistory!]!
  adminChannels: [NotificationChannel!]!
  adminChannel(type: String!): NotificationChannel
  adminChannelStats(type: String!): ChannelStats
  adminQueueStats: QueueStats!
  adminSMTPProviders: [SMTPProvider!]!

}

# ============================================================================
# MUTATION TYPE
# ============================================================================

type Mutation {
  registerUser(username: String!, email: String!, password: String!): AuthResult!
  loginUser(identifier: String!, password: String!, twoFactorCode: String, recoveryKey: String): AuthResult!
  completeUserTwoFactor(sessionToken: String!, twoFactorCode: String!): AuthResult!
  useUserRecoveryKey(sessionToken: String!, recoveryKey: String!): AuthResult!
  logoutUser: GenericResponse!
  refreshUserSession: AuthResult!
  requestPasswordReset(email: String!): GenericResponse!
  resetUserPassword(token: String!, password: String!): GenericResponse!
  verifyUserEmail(token: String!): GenericResponse!
  completeUserInvite(token: String!, username: String!, password: String!): UserInviteCompletion!
  completeServerInvite(token: String!, username: String!, password: String!): ServerInviteCompletion!

  # User Mutations
  updateUserProfile(displayName: String, phone: String): GenericResponse!
  uploadUserAvatar(file: Upload!): PublicAvatar!
  updateUserAvatar(type: String!, url: String): PublicAvatar!
  resetUserAvatar: GenericResponse!
  changeUserPassword(currentPassword: String!, newPassword: String!): GenericResponse!
  enableUserTwoFactor(secret: String!, code: String!): TOTPRecoveryKeys!
  disableUserTwoFactor(password: String!): GenericResponse!
  verifyUserTwoFactor(code: String!): GenericResponse!
  regenerateUserRecoveryKeys(code: String!): TOTPRecoveryKeys!
  updateUserSettings(
    account: AccountSettingsInput
    privacy: PrivacySettingsInput
    notifications: NotificationSettingsInput
    appearance: AppearanceSettingsInput
  ): GenericResponse!
  createUserToken(name: String!, scopes: String, expiresIn: Int): UserToken!
  revokeUserToken(id: ID!): GenericResponse!

  # Saved Locations Mutations
  createSavedLocation(name: String!, lat: Float!, lon: Float!, country: String, region: String, alerts: Boolean): SavedLocation!
  updateSavedLocation(id: ID!, name: String, alerts: Boolean): SavedLocation!
  deleteSavedLocation(id: ID!): GenericResponse!
  toggleLocationAlerts(id: ID!): SavedLocation!

  # Notifications Mutations
  markNotificationRead(id: ID!): Notification!
  markAllNotificationsRead: GenericResponse!
  deleteNotification(id: ID!): GenericResponse!

  # Admin User Mutations
  adminUpdateUser(id: ID!, username: String, email: String, role: String): User!
  adminDeleteUser(id: ID!): GenericResponse!
  adminCreateUserInvite(username: String!, email: String!, role: String, expiresInDays: Int): UserInvite!
  adminDeleteUserInvite(id: ID!): GenericResponse!
  adminInviteServerAdmin(email: String!, expiresIn: String): ServerAdminInvite!
  adminDeleteServerAdmin(id: ID!): GenericResponse!
  adminDisableServerAdmin(id: ID!): GenericResponse!
  adminEnableServerAdmin(id: ID!): GenericResponse!

  # Admin Settings Mutations
  adminUpdateSetting(key: String!, value: String!): Setting!
  adminUpdateSettings(settings: [SettingInput!]!): BulkResponse!
  adminResetSettings: GenericResponse!

  # Admin Token Mutations
  adminGenerateToken: APIToken!
  adminRevokeToken(id: ID!): GenericResponse!

  # Admin Audit Mutations
  adminClearAuditLogs: GenericResponse!

  # Admin Task Mutations
  adminUpdateTask(name: String!, enabled: Boolean!): ScheduledTask!
  adminEnableTask(name: String!): ScheduledTask!
  adminDisableTask(name: String!): ScheduledTask!
  adminTriggerTask(name: String!): GenericResponse!

  # Admin Channel Mutations
  adminUpdateChannel(type: String!, enabled: Boolean, config: Any): NotificationChannel!
  adminEnableChannel(type: String!): NotificationChannel!
  adminDisableChannel(type: String!): NotificationChannel!
  adminTestChannel(type: String!, recipient: String): GenericResponse!
  adminInitializeChannels: GenericResponse!
  adminAutoDetectSMTP: SMTPProvider

  # Contact Form
  submitContactForm(name: String!, email: String!, subject: String!, message: String!): ContactSubmission!

}

# ============================================================================
# INPUT TYPES
# ============================================================================

input SettingInput {
  key: String!
  value: String!
}
