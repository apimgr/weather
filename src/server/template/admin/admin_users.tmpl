{{template "head" .}}
{{template "navbar" .}}
<main class="container">
<div class="admin-header"><h1>👥 User Management</h1></div>
<form id="userSettingsForm">
    <input type="hidden" name="csrf_token" value="{{.csrf_token}}">
<section class="card"><h2>Multi-User Mode</h2>
<label><input type="checkbox" name="enabled"> Enable multi-user mode</label>
</section>
<section class="card"><h2>Registration</h2>
<label for="registration_mode">Registration mode</label>
<select id="registration_mode" name="registration_mode">
    <option value="public">Public</option>
    <option value="private">Private (admin invite only)</option>
    <option value="disabled">Disabled (hidden registration)</option>
</select>
<label><input type="checkbox" name="registration_require_email_verification"> Require email verification</label>
</section>
<button type="submit">Save Settings</button>
</form>
</main>
{{template "footer" .}}
