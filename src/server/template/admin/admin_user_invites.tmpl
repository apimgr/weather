{{template "head" .}}
{{template "navbar" .}}
<main class="container">
  <div class="admin-header"><h1>🔗 User Invites</h1></div>

  {{if .message}}
  <section class="card">
    <p>{{.message}}</p>
    {{if .invite_url}}
    <p><a href="{{.invite_url}}">{{.invite_url}}</a></p>
    {{end}}
  </section>
  {{end}}

  {{if .error}}
  <section class="card">
    <p>{{.error}}</p>
  </section>
  {{end}}

  <section class="card">
    <h2>Create Invite</h2>
    <form method="POST" action="{{.admin_path}}/server/users/invites">
      <input type="hidden" name="csrf_token" value="{{.csrf_token}}">
      <label for="username">Username</label>
      <input id="username" name="username" type="text" required autocomplete="username" value="{{.form.Username}}">

      <label for="email">Email</label>
      <input id="email" name="email" type="email" required autocomplete="email" value="{{.form.Email}}">

      <label for="role">Role</label>
      <input id="role" name="role" type="text" value="{{if .form.Role}}{{.form.Role}}{{else}}user{{end}}">

      <label for="expires_in_days">Invite expiration (days)</label>
      <input id="expires_in_days" name="expires_in_days" type="number" min="1" value="{{if .form.ExpiresInDays}}{{.form.ExpiresInDays}}{{else}}{{.invite_expiration_days}}{{end}}">

      <button type="submit">Generate invite</button>
    </form>
  </section>

  <section class="card">
    <h2>Invite List</h2>
    {{if .invites}}
    <table>
      <thead>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Expires</th>
          <th>Invite URL</th>
        </tr>
      </thead>
      <tbody>
        {{range .invites}}
        <tr>
          <td>{{.username}}</td>
          <td>{{.email}}</td>
          <td>{{.role}}</td>
          <td>{{.status}}</td>
          <td>{{.expires_at}}</td>
          <td><a href="{{.invite_url}}">{{.invite_url}}</a></td>
        </tr>
        {{end}}
      </tbody>
    </table>
    {{else}}
    <p>No invites created yet.</p>
    {{end}}
  </section>
</main>
{{template "footer" .}}
