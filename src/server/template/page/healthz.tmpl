{{template "head" .}}
{{template "navbar" .}}

<main class="container" id="main-content" role="main">
    <div class="admin_header">
        <div>
            <h1>📦 {{.health.Project.Name}}</h1>
            {{if .health.Project.Tagline}}<p class="subtitle">{{.health.Project.Tagline}}</p>{{end}}
            <p>{{.health.Project.Description}}</p>
        </div>
    </div>

    <div class="card margin-y-lg">
        <div class="status-message {{.health_status_class}}">
            <strong>{{.health_status_text}}</strong>
        </div>
        <p class="text-comment">Last checked: <time datetime="{{.health.Timestamp}}">{{.health.Timestamp}}</time></p>
        <p class="text-comment">Auto-refreshing in <span id="health-countdown">30</span>s</p>
    </div>

    <div class="grid grid-2">
        <div class="card">
            <h2 class="text-cyan">ℹ️ Version</h2>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Version</div>
                <div class="stat-box__value"><code>{{.health.Version}}</code></div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Go Version</div>
                <div class="stat-box__value"><code>{{.health.GoVersion}}</code></div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Build</div>
                <div class="stat-box__value"><code>{{.health.Build.Commit}}</code> ({{.health.Build.Date}})</div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Uptime</div>
                <div class="stat-box__value">{{.health.Uptime}}</div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Mode</div>
                <div class="stat-box__value">{{.health.Mode}}</div>
            </div>
        </div>

        <div class="card">
            <h2 class="text-cyan">🔗 Cluster</h2>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Enabled</div>
                <div class="stat-box__value">{{if .health.Cluster.Enabled}}Yes{{else}}No{{end}}</div>
            </div>
            {{if .health.Cluster.Status}}
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Status</div>
                <div class="stat-box__value">{{.health.Cluster.Status}}</div>
            </div>
            {{end}}
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Primary</div>
                <div class="stat-box__value">
                    {{if .health.Cluster.Primary}}
                    <div class="code-wrapper">
                        <code class="mobile-code">{{.health.Cluster.Primary}}</code>
                        <button class="copy-btn" type="button" onclick="copyToClipboard('{{.health.Cluster.Primary}}')">Copy</button>
                    </div>
                    {{else}}
                    <span class="text-comment">Not in cluster mode</span>
                    {{end}}
                </div>
            </div>
            {{if .health.Cluster.NodeCount}}
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Nodes</div>
                <div class="stat-box__value">{{.health.Cluster.NodeCount}}</div>
            </div>
            {{end}}
            {{if .health.Cluster.Role}}
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Role</div>
                <div class="stat-box__value">{{.health.Cluster.Role}}</div>
            </div>
            {{end}}
        </div>
    </div>

    <div class="card margin-y-lg">
        <h2 class="text-cyan">🎛️ Features</h2>
        <ul class="feature-list">
            <li>👥 <strong>Multi-User:</strong> {{if .health.Features.MultiUser}}enabled{{else}}disabled{{end}}</li>
            <li>🌍 <strong>GeoIP:</strong> {{if .health.Features.GeoIP}}enabled{{else}}disabled{{end}}</li>
            <li>
                🧅 <strong>Tor:</strong>
                {{if .health.Features.Tor.Enabled}}
                    {{.health.Features.Tor.Status}}
                    {{if .health.Features.Tor.Hostname}}
                    <div class="code-wrapper margin-y-md">
                        <code class="mobile-code">{{.health.Features.Tor.Hostname}}</code>
                        <button class="copy-btn" type="button" onclick="copyToClipboard('{{.health.Features.Tor.Hostname}}')">Copy</button>
                    </div>
                    {{end}}
                {{else}}
                    disabled
                {{end}}
            </li>
        </ul>
    </div>

    <div class="grid grid-2">
        <div class="card">
            <h2 class="text-cyan">🔧 Component Status</h2>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Database</div>
                <div class="stat-box__value">{{.health.Checks.Database}}</div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Cache</div>
                <div class="stat-box__value">{{.health.Checks.Cache}}</div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Disk</div>
                <div class="stat-box__value">{{.health.Checks.Disk}}</div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Scheduler</div>
                <div class="stat-box__value">{{.health.Checks.Scheduler}}</div>
            </div>
            {{if .health.Checks.Cluster}}
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Cluster</div>
                <div class="stat-box__value">{{.health.Checks.Cluster}}</div>
            </div>
            {{end}}
            {{if .health.Checks.Tor}}
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Tor</div>
                <div class="stat-box__value">{{.health.Checks.Tor}}</div>
            </div>
            {{end}}
        </div>

        <div class="card">
            <h2 class="text-cyan">📈 Server Statistics</h2>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Total Requests</div>
                <div class="stat-box__value">{{.health.Stats.RequestsTotal}}</div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Requests (24h)</div>
                <div class="stat-box__value">{{.health.Stats.Requests24H}}</div>
            </div>
            <div class="stat-box margin-y-md">
                <div class="stat-box__label">Active Connections</div>
                <div class="stat-box__value">{{.health.Stats.ActiveConnections}}</div>
            </div>
        </div>
    </div>

    {{if .health.Maintenance}}
    <div class="card margin-y-lg">
        <h2 class="text-cyan">⚠️ Maintenance</h2>
        <p><strong>Reason:</strong> {{.health.Maintenance.Reason}}</p>
        <p><strong>Message:</strong> {{.health.Maintenance.Message}}</p>
    </div>
    {{end}}
</main>

<script>
function copyToClipboard(text) {
    if (!navigator.clipboard) {
        return;
    }
    navigator.clipboard.writeText(text).then(function() {
        if (typeof Toast !== 'undefined') {
            Toast.success('Copied to clipboard!');
        }
    }).catch(function() {
        if (typeof Toast !== 'undefined') {
            Toast.error('Failed to copy');
        }
    });
}

(function() {
    var remaining = 30;
    var countdown = document.getElementById('health-countdown');
    if (!countdown) {
        return;
    }
    setInterval(function() {
        remaining -= 1;
        if (remaining <= 0) {
            window.location.reload();
            return;
        }
        countdown.textContent = String(remaining);
    }, 1000);
})();
</script>

{{template "footer" .}}
