{{define "navbar"}}
<nav class="navbar" role="navigation" aria-label="Main navigation">
    <div class="navbar-container">
        <!-- Brand Logo -->
        <a href="/" class="navbar-brand" aria-label="{{.server.Title}} home page" title="Go to home page">
            <span class="navbar-brand-icon" aria-hidden="true">🌤️</span>
            <span class="navbar-brand-text">{{.server.Title}}</span>
        </a>

        <!-- Desktop Navigation Menu -->
        <div class="navbar-menu" role="menubar">
            <a href="/" class="navbar-link {{if eq .page "weather"}}active{{end}}" role="menuitem" aria-label="{{t .lang "nav.home"}}" title="View current weather conditions">{{t .lang "nav.home"}}</a>
            <a href="/moon" class="navbar-link {{if eq .page "moon"}}active{{end}}" role="menuitem" aria-label="{{t .lang "nav.moon"}}" title="View moon phases and lunar information">{{t .lang "nav.moon"}}</a>
            <a href="/severe-weather" class="navbar-link {{if eq .page "severe-weather"}}active{{end}}" role="menuitem" aria-label="{{t .lang "nav.alerts"}}" title="View severe weather alerts and warnings">{{t .lang "nav.alerts"}}</a>
            <a href="/earthquake" class="navbar-link {{if eq .page "earthquake"}}active{{end}}" role="menuitem" aria-label="{{t .lang "nav.earthquakes"}}" title="View recent earthquake activity">{{t .lang "nav.earthquakes"}}</a>
            <a href="/users/dashboard" class="navbar-link {{if eq .page "dashboard"}}active{{end}}" role="menuitem" aria-label="{{t .lang "nav.settings"}}" title="View your saved locations and preferences">{{t .lang "nav.settings"}}</a>
        </div>

        <!-- Right Side Actions -->
        <div class="navbar-actions">
            <!-- Language Selector per AI.md PART 31 -->
            <div class="lang-selector">
                <select
                    aria-label="{{t .lang "common.select_language"}}"
                    title="{{t .lang "common.select_language"}}"
                    onchange="window.location.search='?lang='+this.value"
                    class="lang-select">
                    {{range .available_languages}}
                    <option value="{{.Code}}" {{if eq .Code $.lang}}selected{{end}}>{{.NativeName}}</option>
                    {{end}}
                </select>
            </div>

            <!-- Notification Bell per AI.md lines 21581-21650 -->
            <div class="notification-bell" aria-label="Notifications">
                <button class="bell-button" onclick="Dropdown.toggle('notification-dropdown', 'notification-bell')" aria-haspopup="true" aria-expanded="false" title="View notifications">
                    <svg class="bell-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path d="M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z"/>
                    </svg>
                    <span id="notification-badge" class="badge" aria-live="polite" role="status"></span>
                </button>
                <div class="notification-dropdown" id="notification-dropdown" role="menu" hidden>
                    <div class="dropdown-header">
                        <span>Notifications</span>
                        <button class="mark-all-read" onclick="Notifications.markAllRead()">Mark all read</button>
                    </div>
                    <div class="notification-list" id="notification-list">
                        <div class="notification-empty">No notifications</div>
                    </div>
                    <a href="/users/notifications" class="dropdown-footer">View all</a>
                </div>
            </div>

            <!-- Profile Avatar with Dropdown -->
            <div class="profile-avatar">
                <button class="avatar" onclick="Dropdown.toggle('profile-dropdown', 'profile-avatar')" id="profile-avatar" aria-label="User menu" aria-haspopup="true" aria-expanded="false" title="Open user menu - Access profile, notifications, and logout" role="button" tabindex="0" onkeydown="if(event.key==='Enter'||event.key===' '){Dropdown.toggle('profile-dropdown','profile-avatar');event.preventDefault();}">
                    {{if .user.Email}}
                        {{ index .user.Email 0 | printf "%c" | upper }}
                    {{else}}
                        U
                    {{end}}
                </button>
                <div class="profile-dropdown" id="profile-dropdown" role="menu" aria-labelledby="profile-avatar">
                    <div class="profile-dropdown-header">
                        <div>
                            {{if .user.Email}}
                                {{if .user.DisplayName}}
                                    {{.user.DisplayName}}
                                {{else if .user.Username}}
                                    {{.user.Username}}
                                {{else}}
                                    {{.user.Email}}
                                {{end}}
                            {{else}}
                                Guest
                            {{end}}
                        </div>
                        <div class="profile-dropdown-role">
                            {{if .user.Role}}
                                {{if ne .user.Role "guest"}}
                                    {{.user.Role}}
                                {{else}}
                                    {{t .lang "nav.login"}}
                                {{end}}
                            {{else}}
                                {{t .lang "nav.login"}}
                            {{end}}
                        </div>
                    </div>
                    <nav class="profile-dropdown-menu">
                        <a href="/users/profile" class="profile-dropdown-item" role="menuitem" title="View and edit your profile settings">👤 Profile</a>
                        <a href="/users/settings" class="profile-dropdown-item" role="menuitem" title="Account settings">⚙️ {{t .lang "nav.settings"}}</a>
                        <a href="/users/security" class="profile-dropdown-item" role="menuitem" title="Password, 2FA, sessions">🔒 Security</a>
                        <a href="/users/tokens" class="profile-dropdown-item" role="menuitem" title="Manage API tokens">🔑 API Tokens</a>
                        <div class="dropdown-divider" role="separator"></div>
                        <!-- Theme toggle per AI.md lines 21676-21698 -->
                        <div class="profile-dropdown-item theme-toggle-row">
                            <span>Theme:</span>
                            <button onclick="Theme.set('dark')" class="theme-btn" data-theme="dark" title="Dark theme">Dark</button>
                            <span class="theme-sep">|</span>
                            <button onclick="Theme.set('light')" class="theme-btn" data-theme="light" title="Light theme">Light</button>
                            <span class="theme-sep">|</span>
                            <button onclick="Theme.set('auto')" class="theme-btn" data-theme="auto" title="Auto theme">Auto</button>
                        </div>
                        <div class="dropdown-divider" role="separator"></div>
                        <a href="/server/help" class="profile-dropdown-item" role="menuitem" title="Help documentation">❓ Help</a>
                        <a href="/auth/logout" class="profile-dropdown-item" role="menuitem" title="Sign out of your account">🚪 {{t .lang "nav.logout"}}</a>
                    </nav>
                </div>
            </div>

            <!-- Mobile Menu Toggle -->
            <button class="mobile-menu-toggle" onclick="Dropdown.toggle('mobile-menu', 'mobile-menu-toggle')" id="mobile-menu-toggle" aria-label="Toggle mobile navigation menu" aria-expanded="false" aria-controls="mobile-menu" title="Open mobile navigation menu" onkeydown="if(event.key==='Enter'||event.key===' '){Dropdown.toggle('mobile-menu','mobile-menu-toggle');event.preventDefault();}">
                ☰
            </button>
        </div>
    </div>

    <!-- Mobile Navigation Menu -->
    <div class="mobile-menu" id="mobile-menu" role="menu" aria-label="Mobile navigation">
        <a href="/" class="mobile-menu-item" role="menuitem" title="View current weather">{{t .lang "nav.home"}}</a>
        <a href="/moon" class="mobile-menu-item" role="menuitem" title="View moon phases">{{t .lang "nav.moon"}}</a>
        <a href="/severe-weather" class="mobile-menu-item" role="menuitem" title="View severe weather alerts">{{t .lang "nav.alerts"}}</a>
        <a href="/earthquake" class="mobile-menu-item" role="menuitem" title="View earthquakes">{{t .lang "nav.earthquakes"}}</a>
        <a href="/users/dashboard" class="mobile-menu-item" role="menuitem" title="View your dashboard">{{t .lang "nav.settings"}}</a>
    </div>
</nav>

<script>
    // Initialize notifications on page load
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof Notifications !== 'undefined') {
            Notifications.fetch();
            Notifications.startPolling(60000);
        }
    });
</script>
{{end}}
