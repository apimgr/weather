{
  "name": "console-weather",
  "version": "1.0.0",
  "description": "A free console-oriented weather service using open data sources",
  "main": "src/server.js",
  "homepage": "http://wthr.top",
  "repository": {
    "type": "git",
    "url": "https://github.com/apimgr/weather.git"
  },
  "bugs": {
    "url": "https://github.com/apimgr/weather/issues"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "chalk": "^4.1.2",
    "cors": "^2.8.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "figlet": "^1.7.0",
    "geoip-lite": "^1.4.10",
    "helmet": "^8.0.0",
    "morgan": "^1.10.1",
    "node-cache": "^5.1.2",
    "suncalc": "^1.9.0"
  },
  "devDependencies": {
    "eslint": "^9.13.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.7",
    "prettier": "^3.3.3"
  },
  "overrides": {
